name: SILMARIL Reset

# Manual-trigger workflow to wipe all accumulated data and start fresh.
# Use this when you want to begin a clean tracking period for live data.
#
# Trigger from Actions tab → "SILMARIL Reset" → Run workflow.

on:
  workflow_dispatch:
    inputs:
      confirm:
        description: 'Type "RESET" to confirm wipe of all tracking data'
        required: true
        default: ''

permissions:
  contents: write

jobs:
  reset:
    runs-on: ubuntu-latest
    if: github.event.inputs.confirm == 'RESET'
    steps:
      - name: Check out repo
        uses: actions/checkout@v4

      - name: Wipe data
        run: |
          cd docs/data
          # Wipe all stateful data files. Keep only metadata files.
          for f in scoring.json history.json risk_state.json \
                   agent_portfolios.json scrooge.json midas.json \
                   cryptobro.json jrr_token.json sports_bro.json \
                   sports_markets.json catalysts.json charts.json \
                   handoff_blocks.json signals.json trade_plans.json; do
            if [ -f "$f" ]; then
              rm -f "$f"
              echo "Removed $f"
            fi
          done

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run SILMARIL with clean state
        env:
          FINNHUB_API_KEY: ${{ secrets.FINNHUB_API_KEY }}
          EIA_API_KEY: ${{ secrets.EIA_API_KEY }}
        run: |
          python -m silmaril --live --output docs/data --verbose

      - name: Commit clean state
        run: |
          git config --local user.email "silmaril-bot@users.noreply.github.com"
          git config --local user.name "SILMARIL Bot"
          git add docs/data/
          if git diff --staged --quiet; then
            echo "No changes."
          else
            git commit -m "✦ SILMARIL clean reset — $(date -u +%Y-%m-%d)"
            git push
          fi
